{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(npm test*)",
      "Bash(npm run tauri*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx playwright*)",
      "Bash(npx wdio*)",
      "Bash(cargo test*)",
      "Bash(cargo check*)",
      "Bash(cargo clippy*)",
      "Bash(cargo build*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(git*)",
      "Grep",
      "Glob"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
